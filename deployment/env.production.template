# EmotionAI API Production Environment Configuration
# Copy this file to .env and update with your actual values
# DO NOT commit the actual .env file to version control!

# Application Settings
APP_NAME=EmotionAI API - Production
ENVIRONMENT=production
DEBUG=false
VERSION=2.0.0

# Database Configuration (RDS PostgreSQL)
# Replace with your actual RDS endpoint and credentials
DATABASE_URL=postgresql://emotionai_user:YOUR_SECURE_PASSWORD@your-rds-endpoint.region.rds.amazonaws.com:5432/emotionai_prod
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Redis Configuration (ElastiCache or local Redis)
# If using ElastiCache, replace with your actual endpoint
REDIS_URL=redis://your-elasticache-endpoint:6379
REDIS_DB=0
REDIS_PASSWORD=

# Security Configuration
# Generate a new secret key with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=REPLACE_WITH_SECURE_32_CHARACTER_SECRET_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Configuration
# Replace with your actual domain(s)
CORS_ORIGINS=["https://yourdomain.com", "https://www.yourdomain.com", "https://api.yourdomain.com"]
TRUSTED_HOSTS=["yourdomain.com", "www.yourdomain.com", "api.yourdomain.com"]

# LLM API Configuration
# Get keys from OpenAI and Anthropic
OPENAI_API_KEY=sk-your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
DEFAULT_LLM_MODEL=gpt-4o-mini
MAX_TOKENS=500
TEMPERATURE=0.7
LLM_TIMEOUT=30

# Performance Settings (optimized for t2.micro)
RATE_LIMIT_REQUESTS=50
RATE_LIMIT_WINDOW=3600
MAX_MEMORY_ITEMS=50
MEMORY_CLEANUP_INTERVAL=3600
AGENT_TIMEOUT=30
MAX_ACTIVE_AGENTS=100

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Vector Database (if using)
VECTOR_DB_TYPE=chromadb
CHROMADB_PATH=./data/chromadb

# Monitoring Configuration
LOG_LEVEL=INFO
ENABLE_METRICS=true
METRICS_PORT=8080
HEALTH_CHECK_INTERVAL=60

# Security Features
ENABLE_HTTPS_REDIRECT=true
# ENABLE_CRISIS_DETECTION=true  # Removed - replaced by intelligent tagging
ENABLE_EVENT_BUS=true
ENABLE_ANALYTICS=true

# Production Optimization
WORKERS=2  # For t2.micro (1 CPU)
WORKER_CLASS=uvicorn.workers.UvicornWorker
TIMEOUT=60
KEEPALIVE=30
MAX_REQUESTS=1000
MAX_REQUESTS_JITTER=50

# Domain Configuration
DOMAIN_NAME=yourdomain.com
API_PREFIX=/api/v1

# Feature Flags
ENABLE_REGISTRATION=true
ENABLE_EMAIL_VERIFICATION=false
ENABLE_PASSWORD_RESET=true
ENABLE_RATE_LIMITING=true
ENABLE_API_DOCS=false  # Disable in production for security

# Cache Configuration
CACHE_TTL=3600  # 1 hour
CACHE_MAX_SIZE=1000